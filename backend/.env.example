NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=minecraft_tracker
DB_USER=postgres
DB_PASSWORD=postgres

# Minecraft OAuth (register at https://account.live.com/developers/applications)
MINECRAFT_CLIENT_ID=your-client-id-here
MINECRAFT_CLIENT_SECRET=your-client-secret-here
REDIRECT_URI=http://localhost:8080/oauth/callback

# JWT
JWT_SECRET=your-random-secret-key-change-in-production

# CORS
CORS_ORIGIN=http://localhost:5173

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379
